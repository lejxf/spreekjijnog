      "id": "hagenese-hipster",
      "name": "Hagenese Hipster",
      "description": "Werkt iets met design of strategie, woont in een appartement met witte muren en één Charles Eames-stoel. Mengt formele uitdrukkingen met losse jongerentaal alsof dat normaal is. En het is ook normaal, blijkbaar.",
      "axes": { "generation_min": 1985, "generation_max": 2000, "region": "zuid-holland/hollands", "register": "informeel" },
      "colors": { "bg": "#1a2b32", "accent": "#9ee0c0", "text": "#ffffff" }
    },
